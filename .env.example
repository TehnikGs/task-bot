# ===== Telegram =====
# Токен бота от @BotFather
BOT_TOKEN=

# Telegram ID начальника (кто ставит задачи голосом).
# Узнать: напиши боту /id — он пришлёт твой ID.
BOSS_ID=

# Telegram ID сотрудника (кто выполняет задачи кнопками).
EMPLOYEE_ID=

# ID группы (необязательно, на будущее).
GROUP_ID=

# ===== Бесплатный ИИ (понимание смысла) =====
# Бесплатный ключ Groq: https://console.groq.com/keys
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ===== Распознавание речи =====
# groq  — бесплатный облачный Whisper (по умолчанию, использует тот же ключ Groq)
# local — faster-whisper на самом сервере (без оплаты, но нужны ресурсы;
#         тогда раскомментируй faster-whisper в requirements.txt)
STT_BACKEND=groq
STT_MODEL=whisper-large-v3
# Если распознавание на ОТДЕЛЬНОМ ключе/сервисе — задай тут, иначе берётся LLM_API_KEY:
STT_API_KEY=
STT_BASE_URL=https://api.groq.com/openai/v1
# Модель для local-режима (tiny/base/small/medium):
STT_LOCAL_MODEL=small

# ===== Прокси (нужен, если сервер в РФ не достаёт Telegram/Groq) =====
# Примеры: socks5://user:pass@1.2.3.4:1080  или  http://1.2.3.4:3128
# Для socks5:// нужны пакеты из requirements (aiohttp-socks, httpx[socks]).
TELEGRAM_PROXY=
# Прокси для Groq. Если пусто — берётся TELEGRAM_PROXY (обычно один и тот же).
LLM_PROXY=

# ===== Прочее =====
DB_PATH=tasks.db
DEBUG=
